datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Lead {
  id               String   @id @default(uuid())
  nome             String
  telefone         String
  email            String
  empresa          String
  mensagem         String?
  origem_da_pagina String?
  status           String   @default("novo")
  responsavel      String?
  observacoes      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model SiteSettings {
  id                    String   @id @default(uuid())
  google_tag_manager_id String?
  google_analytics_id   String?
  google_ads_id         String?
  meta_pixel_id         String?
  script_head           String?
  script_body           String?
  notificacao_email     Boolean  @default(false)
  notificacao_whatsapp  Boolean  @default(false)
  smtp_host             String?
  smtp_port             String?
  smtp_user             String?
  smtp_pass             String?
  destinatario_email    String?
  api_whatsapp_url      String?
  api_whatsapp_token    String?
  telefone_notificacao  String?
  updatedAt             DateTime @updatedAt
}

model WhatsappSettings {
  id              String   @id @default(uuid())
  numero_whatsapp String   @default("5511999999999")
  texto_botao     String   @default("Falar no WhatsApp")
  mensagem_padrao String   @default("Olá! Vim pelo site da QAO e gostaria de entender como vocês podem ajudar minha empresa a crescer.")
  botao_ativo     Boolean  @default(true)
  posicao_botao   String   @default("direita")
  updatedAt       DateTime @updatedAt
}

model SystemLog {
  id        String   @id @default(uuid())
  level     String   @default("info") // info, warning, error, success
  source    String   // Ex: webhook_evolution, lead_capture
  message   String
  details   String?
  createdAt DateTime @default(now())
}
